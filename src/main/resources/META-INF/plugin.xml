<idea-plugin>
   <id>org.teamtype</id>

   <name>Teamtype</name>
   <vendor url="https://teamtype.org">teamtype.org</vendor>

   <description><![CDATA[
   Teamtype enables real-time co-editing of local text files. You can use it for pair programming or note-taking, for example! Think Google Docs, but from the comfort of your favorite text editor!
   ]]></description>

   <depends>com.intellij.modules.platform</depends>
   <depends>org.jetbrains.plugins.terminal</depends>

   <extensions defaultExtensionNs="com.intellij">
      <applicationService
         serviceImplementation="org.teamtype.settings.AppSettings"/>
      <applicationConfigurable
         parentId="tools"
         instance="org.teamtype.settings.AppSettingsConfigurable"
         id="org.teamtype.settings.AppSettingsConfigurable"
         displayName="Teamtype"/>

      <projectService
         serviceInterface="org.teamtype.TeamtypeService"
         serviceImplementation="org.teamtype.TeamtypeServiceImpl"/>

      <toolWindow
           id="teamtype"
           icon="/toolbar.svg"
           factoryClass="org.teamtype.ui.TeamtypeToolWindowFactory"/>

      <terminal.shellCommandHandler
           implementation="org.teamtype.StartTeamtypeDaemonTerminalShellCommandHandler"/>
      <iconMapper mappingFile="TeamtypeIconMappings.json"/>
   </extensions>

   <actions>
      <action
         id="StartTeamtypeDaemon"
         class="org.teamtype.StartTeamtypeDaemonAction"
         text="Code with Teamtype"
         description="Connect to a running teamtype daemon or start a new peer"
         icon="/toolbar.svg">
         <add-to-group group-id="ToolsMenu" anchor="first"/>
      </action>
   </actions>
</idea-plugin>
