<idea-plugin>
   <id>org.teamtype</id>

   <name>Teamtype</name>
   <vendor url="https://teamtype.org">teamtype.org</vendor>

   <description><![CDATA[
   Ethersync enables real-time co-editing of local text files. You can use it for pair programming or note-taking, for example! Think Google Docs, but from the comfort of your favorite text editor!
   ]]></description>

   <depends>com.intellij.modules.platform</depends>
   <depends>org.jetbrains.plugins.terminal</depends>

   <extensions defaultExtensionNs="com.intellij">
      <applicationService
         serviceImplementation="org.teamtype.settings.AppSettings"/>
      <applicationConfigurable
         parentId="tools"
         instance="org.teamtype.settings.AppSettingsConfigurable"
         id="org.teamtype.settings.AppSettingsConfigurable"
         displayName="Ethersync"/>

      <projectService
         serviceInterface="org.teamtype.EthersyncService"
         serviceImplementation="org.teamtype.EthersyncServiceImpl"/>

      <toolWindow
           id="ethersync"
           icon="/toolbar.svg"
           factoryClass="org.teamtype.ui.EthersyncToolWindowFactory"/>

      <terminal.shellCommandHandler
           implementation="org.teamtype.StartEthersyncDaemonTerminalShellCommandHandler"/>
      <iconMapper mappingFile="EthersyncIconMappings.json"/>
   </extensions>

   <actions>
      <action
         id="StartEthersyncDaemon"
         class="org.teamtype.StartEthersyncDaemonAction"
         text="Code with Ethersync"
         description="Connect to a running ethersync daemon or start a new peer"
         icon="/toolbar.svg">
         <add-to-group group-id="ToolsMenu" anchor="first"/>
      </action>
   </actions>
</idea-plugin>
